# === STAGE 1: COMPILATION ===
FROM node:22-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

# === STAGE 2: PRODUCTION ENVIRONMENT ===
FROM nginx:stable-alpine

# 1. Copy over your built static site assets
COPY --from=builder /app/dist /usr/share/nginx/html

# 2. Delete the default config *inside* the active Nginx environment layer 
RUN rm /etc/nginx/conf.d/default.conf

# 3. Overwrite the absolute master config file
COPY nginx.conf /etc/nginx/nginx.conf

# 4. Open up both standard HTTP and secure HTTPS doorways
EXPOSE 80 443

CMD ["nginx", "-g", "daemon off;"]